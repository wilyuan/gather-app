# Supabase credentials (from your Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Google Places API key (from Google Cloud Console)
# Free tier: $200/month credit (~5000 requests, more than enough)
# Get it: https://console.cloud.google.com → APIs → Places API → Credentials
GOOGLE_PLACES_API_KEY=your-google-api-key-here
